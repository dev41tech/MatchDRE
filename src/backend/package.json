{
  "name": "match-dre-backend",
  "version": "1.0.0",
  "description": "Backend para mapeamento de categorias DRE",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --testPathPattern=unit",
    "test:properties": "jest --testPathPattern=properties",
    "test:all": "jest"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mysql2": "^3.10.0"
  },
  "devDependencies": {
    "fast-check": "^3.20.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
